<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <MinVerTagPrefix>v</MinVerTagPrefix>
        <PackageReadmeFile>readme.md</PackageReadmeFile>
        <Description>A lightweight, zero-configuration log throttler for Microsoft.Extensions.Logging. Suppress high-frequency repeated log entries per key and automatically report the suppressed count when logging resumes — with no setup or disposal    
  required.</Description>
        <PackageTags>log,throttle</PackageTags>
    </PropertyGroup>
    
    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    </ItemGroup>

    <ItemGroup>
        <None Include="readme.md">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
    </ItemGroup>

</Project>
